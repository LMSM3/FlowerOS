    "profiles": {
        "defaults": {
            "//": "Default settings for all profiles",
            "font": {
                "face": "CaskaydiaCove Nerd Font",
                "size": 11,
                "weight": "normal"
            },
            "opacity": 90,
            "useAcrylic": true,
            "acrylicOpacity": 0.9,
            "colorScheme": "FlowerOS Dracula",
            "cursorShape": "filledBox",
            "cursorHeight": 25,
            "bellStyle": "none",
            "padding": "8, 8, 8, 8",
            "scrollbarState": "hidden",
            "antialiasingMode": "cleartype",
            "experimental.retroTerminalEffect": false,
            "intenseTextStyle": "bold",
            "backgroundImage": null,
            "backgroundImageOpacity": 0.3,
            "backgroundImageStretchMode": "uniformToFill"
        },
        "list": [
            {
                "name": "PowerShell FlowerOS",
                "commandline": "pwsh.exe -NoLogo",
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "hidden": false,
                "icon": "🌸",
                "colorScheme": "FlowerOS Dracula",
                "opacity": 92,
                "useAcrylic": true,
                "font": {
                    "face": "CaskaydiaCove Nerd Font",
                    "size": 11
                },
                "startingDirectory": "%USERPROFILE%"
            },
            {
                "name": "Bash FlowerOS (WSL)",
                "commandline": "wsl.exe",
                "guid": "{2c4de342-38b7-51cf-b940-2309a097f518}",
                "hidden": false,
                "icon": "🌺",
                "colorScheme": "FlowerOS Tokyo Night",
                "opacity": 90,
                "useAcrylic": true,
                "font": {
                    "face": "CaskaydiaCove Nerd Font",
                    "size": 11
                },
                "startingDirectory": "~"
            }
        ]
    },
    
    "actions": [
        {
            "command": "find",
            "keys": "ctrl+shift+f"
        },
        {
            "command": {
                "action": "splitPane",
                "split": "auto",
                "splitMode": "duplicate"
            },
            "keys": "alt+shift+d"
        },
        {
            "command": "toggleFocusMode",
            "keys": "f11"
        },
        {
            "command": "toggleFullscreen",
            "keys": "alt+enter"
        }
    ]
}
