#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════
#  flower  --  FlowerOS command entry point
#
#  Usage:
#    flower [--version|-v]   Show version and install date
#    flower [--help|-h]      Show this message
#    flower tree             Show installed file tree
#
#  Version file searched in priority order:
#    $FLOWEROS_CONFIG/VERSION  (runtime export)
#    ~/.floweros/VERSION        (user install)
#    /etc/floweros/VERSION      (permanent install)
# ═══════════════════════════════════════════════════════════════════════════

set -uo pipefail

readonly _F_MAG='\033[35m'
readonly _F_CYN='\033[36m'
readonly _F_GRN='\033[32m'
readonly _F_YLW='\033[33m'
readonly _F_BLD='\033[1m'
readonly _F_RST='\033[0m'

# ── Resolve script's own repo root ────────────────────────────────────────
_FLOWER_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
_FLOWER_REPO_ROOT="$(cd "$_FLOWER_SCRIPT_DIR/.." 2>/dev/null && pwd)"

# ── Locate the VERSION file ──────────────────────────────────────────────
_find_version_file() {
  local candidates=(
    "${FLOWEROS_CONFIG:-__none__}/VERSION"
    "${HOME}/.floweros/VERSION"
    "/etc/floweros/VERSION"
    "${FLOWEROS_ROOT:-__none__}/VERSION"
    "${_FLOWER_REPO_ROOT}/VERSION"
  )
  for f in "${candidates[@]}"; do
    [[ -f "$f" ]] && { printf '%s' "$f"; return 0; }
  done
  return 1
}

# ── Commands ─────────────────────────────────────────────────────────────
_cmd_version() {
  local vfile
  echo ""
  if vfile="$(_find_version_file)"; then
    local ver build_type installed
    # Installed VERSION file uses multi-line format:
    #   FlowerOS v1.3.0
    #   Build: user
    #   Installed: 2025-01-15 ...
    # Repo VERSION file is a single plain version string: 1.3.0
    ver="$(grep '^FlowerOS ' "$vfile" | sed 's/^FlowerOS //' || true)"
    if [[ -z "$ver" ]]; then
      # Plain version string (repo-root VERSION)
      ver="v$(head -1 "$vfile" | tr -d '[:space:]')"
    fi
    build_type="$(grep '^Build: ' "$vfile" | sed 's/^Build: //' || true)"
    installed="$(grep '^Installed: ' "$vfile" | sed 's/^Installed: //' || true)"
    printf "${_F_MAG}${_F_BLD}FlowerOS${_F_RST}\n"
    printf "  %-14s ${_F_GRN}%s${_F_RST}\n" "Version"   "${ver:-unknown}"
    [[ -n "$build_type" ]] && printf "  %-14s %s\n" "Build"     "$build_type"
    [[ -n "$installed" ]]  && printf "  %-14s %s\n" "Installed" "$installed"
    printf "  %-14s ${_F_CYN}%s${_F_RST}\n" "Source"    "$vfile"
  elif [[ -n "${FLOWEROS_VERSION:-}" ]]; then
    # Fallback: env var set by .flowerrc
    printf "${_F_MAG}${_F_BLD}FlowerOS${_F_RST}\n"
    printf "  %-14s ${_F_GRN}v%s${_F_RST}\n" "Version" "$FLOWEROS_VERSION"
    printf "  %-14s %s\n" "Source" "FLOWEROS_VERSION env"
  else
    printf "${_F_MAG}${_F_BLD}FlowerOS${_F_RST}  ${_F_YLW}(VERSION not found)${_F_RST}\n"
    printf "  Expected: %s\n" "~/.floweros/VERSION  or  /etc/floweros/VERSION  or  repo VERSION"
  fi
  echo ""
}

_cmd_help() {
  echo ""
  printf "${_F_MAG}${_F_BLD}flower${_F_RST} / ${_F_MAG}${_F_BLD}floweros${_F_RST} -- FlowerOS entry point\n"
  echo ""
  printf "  ${_F_CYN}%-28s${_F_RST} %s\n" "flower --version, -v"    "Show version and install info"
  printf "  ${_F_CYN}%-28s${_F_RST} %s\n" "flower --tree, tree"     "Show installed file tree"
  printf "  ${_F_CYN}%-28s${_F_RST} %s\n" "flower --help, -h"       "Show this message"
  echo ""
  printf "  ${_F_CYN}%-28s${_F_RST} %s\n" "floweros [any flag]"     "Same as flower (alias)"
  echo ""
}

_cmd_tree() {
  local root="${FLOWEROS_ROOT:-${_FLOWER_REPO_ROOT:-${HOME}/FlowerOS}}"
  echo ""
  printf "${_F_MAG}%s${_F_RST}\n" \
    "===============================================================================" \
    "  FlowerOS -- Installed Layout" \
    "==============================================================================="
  echo ""

  if [[ ! -d "$root" ]]; then
    printf "  Install root not found: %s\n" "$root"
    echo ""
    return 0
  fi

  printf "  Root   : %s\n" "$root"
  printf "  Config : %s\n" "${FLOWEROS_CONFIG:-${HOME}/.floweros}"
  echo ""

  # bin/
  if [[ -d "$root/bin" ]]; then
    printf "  bin/\n"
    for f in "$root/bin"/*; do
      [[ -e "$f" ]] && printf "    %-24s %s\n" "$(basename "$f")" "$(du -h "$f" 2>/dev/null | cut -f1)"
    done
    echo ""
  fi

  # lib/
  if [[ -d "$root/lib" ]]; then
    local lib_count
    lib_count=$(find "$root/lib" -maxdepth 1 -type f 2>/dev/null | wc -l)
    printf "  lib/               (%d shell files)\n" "$lib_count"

    # Flower AI subsystem
    if [[ -d "$root/lib/flower_ai" ]]; then
      printf "    flower_ai/       (optional AI subsystem)\n"
    fi
    echo ""
  fi

  # src/
  if [[ -d "$root/src" ]]; then
    local src_count
    src_count=$(find "$root/src" -type f -name '*.c' -o -name '*.h' -o -name '*.cpp' -o -name '*.hpp' 2>/dev/null | wc -l)
    printf "  src/               (%d source files)\n" "$src_count"
    echo ""
  fi

  # ascii/
  if [[ -d "$root/ascii" ]]; then
    local asc_count
    asc_count=$(find "$root/ascii" -type f 2>/dev/null | wc -l)
    printf "  ascii/             (%d files)\n" "$asc_count"
    echo ""
  fi

  # tier4/
  if [[ -d "$root/tier4" ]]; then
    printf "  tier4/             (Windows substrate)\n"
    echo ""
  fi

  # VERSION
  local vfile
  if vfile="$(_find_version_file)"; then
    printf "  VERSION            %s\n" "$vfile"
  fi

  echo ""
  printf "${_F_MAG}%s${_F_RST}\n" \
    "==============================================================================="
  echo ""
}

# ── Dispatch ──────────────────────────────────────────────────────────────
case "${1:-}" in
  --version|-v|version)  _cmd_version ;;
  --help|-h|help)        _cmd_help ;;
  --tree|tree)           _cmd_tree ;;
  "")                    _cmd_version; sleep 0.8; _cmd_help ;;
  *)
    printf "flower: unknown command '%s'\n\n" "$1" >&2
    _cmd_help
    exit 1
    ;;
esac
