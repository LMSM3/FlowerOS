#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# flower-theme-push
# FlowerOS 0.4.0 (Pollen) — WSL-to-Windows theme file sync
#
# Copies the canonical theme files from the WSL-side config
# directory to the Windows-side mirror, keeping both shells
# reading from an identical set of files.
#
# Usage:
#   flower-theme-push              Push all theme files
#   flower-theme-push --status     Show sync status
#   flower-theme-push --generate   Regenerate config files from active theme
#   flower-theme-push --help       This message
#
# Config layout (both sides):
#   ~/.config/flower/
#     theme.omp.json     Oh My Posh theme (env-driven palette)
#     state.ps1          PowerShell profile loader snippet
#     theme.env          Key=value colour manifest
#     swarm.toml         Swarm/multi-node config (reserved)
#
# Part of FlowerOS 0.4.0 (Pollen) — Core Architecture.
# ─────────────────────────────────────────────────────────────
set -euo pipefail

FOS_VERSION="0.4.0"
FOS_PHASE="Pollen"

# ── Resolve root ────────────────────────────────────────────
_PUSH_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FLOWEROS_ROOT="$(cd "$_PUSH_DIR/.." 2>/dev/null && pwd)"
export FLOWEROS_ROOT
FLOWEROS_LIB="${FLOWEROS_ROOT}/lib"

# ── Detect Windows user ─────────────────────────────────────
# Priority: FLOWER_WIN_USER env → scan /mnt/c/Users for first
# non-system directory
_detect_win_user() {
    if [[ -n "${FLOWER_WIN_USER:-}" ]]; then
        echo "$FLOWER_WIN_USER"
        return
    fi
    local skip="Default|Public|All Users|Default User"
    for d in /mnt/c/Users/*/; do
        local name
        name="$(basename "$d")"
        if [[ ! "$name" =~ ^($skip)$ ]]; then
            echo "$name"
            return
        fi
    done
    echo ""
}

WIN_USER="$(_detect_win_user)"
FOS_CONFIG_DIR="$HOME/.config/flower"

# File names (single source of truth)
THEME_FILE="theme.omp.json"
STATE_FILE="state.ps1"
ENV_FILE="theme.env"
SWARM_CONF="swarm.toml"

SRC_THEME="$FOS_CONFIG_DIR/$THEME_FILE"
SRC_STATE="$FOS_CONFIG_DIR/$STATE_FILE"
SRC_ENV="$FOS_CONFIG_DIR/$ENV_FILE"
SRC_SWARM="$FOS_CONFIG_DIR/$SWARM_CONF"

WIN_BASE="/mnt/c/Users/$WIN_USER/.config/flower"

# ── Colours ─────────────────────────────────────────────────
G='\033[32m' R='\033[31m' C='\033[36m' Y='\033[33m'
M='\033[35m' D='\033[90m' B='\033[1m'  Z='\033[0m'

log()  { printf "${D}[flower-push %s]${Z} %s\n" "$FOS_VERSION" "$1"; }
ok()   { printf "${G}✓${Z} %s\n" "$1"; }
err()  { printf "${R}✗${Z} %s\n" "$1" >&2; exit 1; }
warn() { printf "${Y}⚠${Z} %s\n" "$1"; }

ensure_dir() {
    if [[ ! -d "$1" ]]; then
        mkdir -p "$1"
        log "Created: $1"
    fi
}

sync_file() {
    local src="$1" dst="$2" label="$3"
    if [[ -f "$src" ]]; then
        cp "$src" "$dst"
        ok "Synced $label -> $dst"
    else
        warn "Skipped $label (not found: $src)"
    fi
}

# ═════════════════════════════════════════════════════════════
#  Generate config files from the active FlowerOS theme
# ═════════════════════════════════════════════════════════════

_generate_omp_theme() {
    # Copy the canonical floweros.omp.json into the config dir
    local master="${FLOWEROS_LIB}/floweros.omp.json"
    if [[ -f "$master" ]]; then
        cp "$master" "$SRC_THEME"
        ok "Generated $THEME_FILE from lib/floweros.omp.json"
    else
        warn "$THEME_FILE: master not found at $master"
    fi
}

_generate_theme_env() {
    # Source profile_sync to populate FLOWEROS_OMP_* vars
    if [[ -z "${FLOWEROS_OMP_PRIMARY:-}" ]]; then
        local _guard_save="${_FLOWEROS_PROFILE_SYNCED:-}"
        unset _FLOWEROS_PROFILE_SYNCED
        # shellcheck source=../lib/profile_sync.sh
        source "${FLOWEROS_LIB}/profile_sync.sh" 2>/dev/null || true
        [[ -n "$_guard_save" ]] && export _FLOWEROS_PROFILE_SYNCED="$_guard_save"
    fi

    cat > "$SRC_ENV" <<EOF
# FlowerOS Theme Environment — auto-generated by flower-theme-push
# $(date)
# Phase: $FOS_PHASE $FOS_VERSION
FLOWEROS_THEME_LOADED="${FLOWEROS_THEME_LOADED:-garden}"
FLOWEROS_THEME_VARIANT="${FLOWEROS_THEME_VARIANT:-dark}"
FLOWEROS_DISTRO="${FLOWEROS_DISTRO:-unknown}"
FLOWEROS_OMP_PRIMARY="${FLOWEROS_OMP_PRIMARY:-#5faf5f}"
FLOWEROS_OMP_SECONDARY="${FLOWEROS_OMP_SECONDARY:-#af5faf}"
FLOWEROS_OMP_ACCENT="${FLOWEROS_OMP_ACCENT:-#5fafaf}"
FLOWEROS_OMP_WARNING="${FLOWEROS_OMP_WARNING:-#afaf00}"
FLOWEROS_OMP_ERROR="${FLOWEROS_OMP_ERROR:-#cc4444}"
FLOWEROS_OMP_SUCCESS="${FLOWEROS_OMP_SUCCESS:-#5fdf5f}"
FLOWEROS_OMP_INFO="${FLOWEROS_OMP_INFO:-#5f87df}"
FLOWEROS_OMP_MUTED="${FLOWEROS_OMP_MUTED:-#808080}"
FLOWEROS_OMP_BG="${FLOWEROS_OMP_BG:-#1e1e2e}"
FLOWEROS_OMP_FG="${FLOWEROS_OMP_FG:-#cdd6f4}"
EOF
    ok "Generated $ENV_FILE"
}

_generate_state_ps1() {
    # Detect the Windows-side FlowerOS root
    local win_root="$FLOWEROS_ROOT"
    if [[ "$FLOWEROS_ROOT" == /mnt/* ]]; then
        local drive rest
        drive=$(echo "$FLOWEROS_ROOT" | sed 's|^/mnt/\(.\)/.*|\1|')
        rest=$(echo "$FLOWEROS_ROOT" | sed "s|^/mnt/.||" | tr '/' '\\')
        win_root="${drive^^}:${rest}"
    fi

    local win_config="C:\\Users\\${WIN_USER}\\.config\\flower"

    cat > "$SRC_STATE" <<PSEOF
# ─────────────────────────────────────────────────────────────
# FlowerOS 0.4.0 (Pollen) — PowerShell state loader
# Auto-generated by flower-theme-push — do not edit by hand
#
# Add to your \$PROFILE:
#   . "C:\Users\\${WIN_USER}\\.config\flower\state.ps1"
# ─────────────────────────────────────────────────────────────

# Read theme.env and export colours
\$_fosEnv = Join-Path (Split-Path -Parent \$PSCommandPath) "theme.env"
if (Test-Path \$_fosEnv) {
    foreach (\$_line in (Get-Content \$_fosEnv)) {
        \$_line = \$_line.Trim()
        if (\$_line -match '^#' -or \$_line -eq '') { continue }
        if (\$_line -match '^([A-Z_]+)="?([^"]*)"?\$') {
            [Environment]::SetEnvironmentVariable(\$Matches[1], \$Matches[2], 'Process')
        }
    }
}

# Load full profile sync if available
\$env:FLOWEROS_ROOT = "${win_root}"
\$_fosSync = Join-Path \$env:FLOWEROS_ROOT "lib\profile_sync.ps1"
if (Test-Path \$_fosSync) {
    . \$_fosSync
} else {
    # Minimal OMP init from local theme file
    \$_fosOmp = Join-Path (Split-Path -Parent \$PSCommandPath) "theme.omp.json"
    if ((Get-Command oh-my-posh -ErrorAction SilentlyContinue) -and (Test-Path \$_fosOmp)) {
        oh-my-posh init pwsh --config \$_fosOmp | Invoke-Expression
    }
}
PSEOF
    ok "Generated $STATE_FILE"
}

_generate_swarm_toml() {
    if [[ -f "$SRC_SWARM" ]]; then
        log "Keeping existing $SWARM_CONF"
        return
    fi

    cat > "$SRC_SWARM" <<EOF
# FlowerOS Swarm Configuration — Pollen $FOS_VERSION
# Multi-node theme sync (reserved for future use)

[swarm]
enabled = false
role    = "standalone"    # standalone | primary | replica

[sync]
method    = "file-push"   # file-push | wslenv | git
interval  = "on-change"   # on-change | 5m | 15m | manual
targets   = ["windows"]

[paths]
wsl_config   = "$FOS_CONFIG_DIR"
win_config   = "C:\\Users\\${WIN_USER}\\.config\\flower"
omp_theme    = "$THEME_FILE"
env_manifest = "$ENV_FILE"
EOF
    ok "Generated $SWARM_CONF"
}

generate_all() {
    ensure_dir "$FOS_CONFIG_DIR"
    _generate_omp_theme
    _generate_theme_env
    _generate_state_ps1
    _generate_swarm_toml
}

# ═════════════════════════════════════════════════════════════
#  Push (main)
# ═════════════════════════════════════════════════════════════

cmd_push() {
    echo ""
    printf "${M}─────────────────────────────────────────────────────────────${Z}\n"
    printf "${M}  ${B}🌿 flower-theme-push${Z}${M}  FlowerOS %s (%s)${Z}\n" "$FOS_VERSION" "$FOS_PHASE"
    printf "${M}─────────────────────────────────────────────────────────────${Z}\n"
    echo ""

    log "FlowerOS $FOS_VERSION ($FOS_PHASE) theme push..."

    [[ -z "$WIN_USER" ]] && err "Cannot detect Windows user — set FLOWER_WIN_USER"
    [[ -d "/mnt/c/Users/$WIN_USER" ]] || err "Windows user dir not found: /mnt/c/Users/$WIN_USER"

    # Generate config files if they don't exist
    if [[ ! -f "$SRC_THEME" ]] || [[ ! -f "$SRC_ENV" ]]; then
        log "Config files not found — generating from active theme..."
        generate_all
        echo ""
    fi

    ensure_dir "$WIN_BASE"

    sync_file "$SRC_THEME"  "$WIN_BASE/$THEME_FILE"  "theme"
    sync_file "$SRC_STATE"  "$WIN_BASE/$STATE_FILE"   "state"
    sync_file "$SRC_ENV"    "$WIN_BASE/$ENV_FILE"     "env"
    sync_file "$SRC_SWARM"  "$WIN_BASE/$SWARM_CONF"   "swarm config"

    # Also copy OMP theme to ~/.mytheme.omp.json (legacy compat)
    if [[ -f "$SRC_THEME" ]]; then
        cp "$SRC_THEME" "$HOME/.mytheme.omp.json"
        log "Copied to ~/.mytheme.omp.json (legacy)"
    fi

    # Keep the ~/.floweros/theme_sync.env in sync too (existing system)
    if [[ -f "$SRC_ENV" ]]; then
        mkdir -p "$HOME/.floweros"
        cp "$SRC_ENV" "$HOME/.floweros/theme_sync.env" 2>/dev/null || true
    fi

    echo ""
    ok "Push complete"
    printf "  ${D}Source:  %s${Z}\n" "$FOS_CONFIG_DIR"
    printf "  ${D}Target:  %s${Z}\n" "$WIN_BASE"
    echo ""
}

# ═════════════════════════════════════════════════════════════
#  Status
# ═════════════════════════════════════════════════════════════

cmd_status() {
    echo ""
    printf "${M}─────────────────────────────────────────────────────────────${Z}\n"
    printf "${M}  ${B}🌿 flower-theme-push${Z}${M}  Status${Z}\n"
    printf "${M}─────────────────────────────────────────────────────────────${Z}\n"
    echo ""

    printf "  ${C}Version:${Z}      %s (%s)\n" "$FOS_VERSION" "$FOS_PHASE"
    printf "  ${C}Win user:${Z}     %s\n" "${WIN_USER:-not detected}"
    printf "  ${C}WSL config:${Z}   %s\n" "$FOS_CONFIG_DIR"
    printf "  ${C}Win target:${Z}   %s\n" "$WIN_BASE"
    echo ""

    local files=("$THEME_FILE" "$STATE_FILE" "$ENV_FILE" "$SWARM_CONF")
    printf "  ${Y}── WSL Source ──${Z}\n"
    for f in "${files[@]}"; do
        if [[ -f "$FOS_CONFIG_DIR/$f" ]]; then
            local sz age_s
            sz=$(stat -c %s "$FOS_CONFIG_DIR/$f" 2>/dev/null || echo "?")
            age_s=$(( $(date +%s) - $(stat -c %Y "$FOS_CONFIG_DIR/$f" 2>/dev/null || echo 0) ))
            printf "    ${G}✓${Z} %-22s %6s bytes  (%ds ago)\n" "$f" "$sz" "$age_s"
        else
            printf "    ${R}✗${Z} %-22s missing\n" "$f"
        fi
    done

    echo ""
    printf "  ${Y}── Windows Target ──${Z}\n"
    if [[ -n "$WIN_USER" && -d "/mnt/c/Users/$WIN_USER" ]]; then
        for f in "${files[@]}"; do
            if [[ -f "$WIN_BASE/$f" ]]; then
                local sz age_s
                sz=$(stat -c %s "$WIN_BASE/$f" 2>/dev/null || echo "?")
                age_s=$(( $(date +%s) - $(stat -c %Y "$WIN_BASE/$f" 2>/dev/null || echo 0) ))
                printf "    ${G}✓${Z} %-22s %6s bytes  (%ds ago)\n" "$f" "$sz" "$age_s"
            else
                printf "    ${Y}⚠${Z} %-22s not pushed yet\n" "$f"
            fi
        done
    else
        printf "    ${R}✗${Z} Windows user directory not found\n"
    fi

    echo ""

    # Diff check
    if [[ -n "$WIN_USER" && -d "$WIN_BASE" ]]; then
        local in_sync=true
        for f in "${files[@]}"; do
            if [[ -f "$FOS_CONFIG_DIR/$f" && -f "$WIN_BASE/$f" ]]; then
                if ! diff -q "$FOS_CONFIG_DIR/$f" "$WIN_BASE/$f" >/dev/null 2>&1; then
                    warn "$f differs between WSL and Windows"
                    in_sync=false
                fi
            fi
        done
        if $in_sync; then
            ok "All synced files are identical"
        fi
    fi
    echo ""
}

# ═════════════════════════════════════════════════════════════
#  Help
# ═════════════════════════════════════════════════════════════

cmd_help() {
    echo ""
    printf "${M}─────────────────────────────────────────────────────────────${Z}\n"
    printf "${M}  ${B}🌿 flower-theme-push${Z}${M}  FlowerOS %s (%s)${Z}\n" "$FOS_VERSION" "$FOS_PHASE"
    printf "${M}─────────────────────────────────────────────────────────────${Z}\n"
    echo ""
    printf "${Y}── USAGE ──${Z}\n\n"
    printf "  ${C}flower-theme-push${Z}              Push theme files WSL -> Windows\n"
    printf "  ${C}flower-theme-push --status${Z}     Show file sync status\n"
    printf "  ${C}flower-theme-push --generate${Z}   Regenerate config from active theme\n"
    printf "  ${C}flower-theme-push --help${Z}       This message\n"
    echo ""
    printf "${Y}── FILES SYNCED ──${Z}\n\n"
    printf "  ${D}%-22s  %s${Z}\n" "$THEME_FILE"  "Oh My Posh theme (env-driven palette)"
    printf "  ${D}%-22s  %s${Z}\n" "$STATE_FILE"   "PowerShell loader snippet"
    printf "  ${D}%-22s  %s${Z}\n" "$ENV_FILE"     "Key=value colour manifest"
    printf "  ${D}%-22s  %s${Z}\n" "$SWARM_CONF"   "Multi-node config (reserved)"
    echo ""
    printf "${Y}── CONFIG ──${Z}\n\n"
    printf "  ${D}WSL source:${Z}  %s\n" "$FOS_CONFIG_DIR"
    printf "  ${D}Win target:${Z}  %s\n" "$WIN_BASE"
    printf "  ${D}Win user:${Z}    %s (override: FLOWER_WIN_USER)\n" "${WIN_USER:-auto-detected}"
    echo ""
    printf "${Y}── INTEGRATION ──${Z}\n\n"
    printf "  ${D}Add to ~/.bashrc:${Z}\n"
    printf "  ${C}%s${Z}\n\n" "eval \"\$(oh-my-posh init bash --config ~/.mytheme.omp.json)\""
    printf "  ${D}Add to PowerShell \$PROFILE:${Z}\n"
    printf "  ${C}%s${Z}\n" ". \"C:\\Users\\${WIN_USER}\\.config\\flower\\state.ps1\""
    echo ""
}

# ═════════════════════════════════════════════════════════════
#  Dispatch
# ═════════════════════════════════════════════════════════════

case "${1:-}" in
    --status|-s|status)     cmd_status ;;
    --generate|-g|generate) generate_all ;;
    --help|-h|help)         cmd_help ;;
    *)                      cmd_push ;;
esac
