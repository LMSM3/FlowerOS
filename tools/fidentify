def cmd_interactive():
    """Interactive mode — prompt for image path, loop until quit."""
    _banner()
    total = _ensure_db()
    print(f"  {GRN}✓ Calflora DB ready — {total} taxa{RST}")
    print()
    print(f"  {CYN}Drag-and-drop an image path, or type it in.{RST}")
    print(f"  {CYN}Commands: {BLD}q{RST}{CYN}/quit, {BLD}history{RST}{CYN}, "
          f"{BLD}search <term>{RST}{CYN}, {BLD}color <color>{RST}")
    print(f"  {DIM}Accepts WSL, Windows, or /mnt/ paths.{RST}")

    while True:
        print()
        try:
            raw = input(f"  {MAG}fidentify ❯{RST} ").strip()
        except (EOFError, KeyboardInterrupt):
            print(f"\n  {DIM}Goodbye 🌸{RST}\n")
            break

        if not raw:
            continue
        low = raw.lower()

        # Quit
        if low in ("q", "quit", "exit"):
            print(f"  {DIM}Goodbye 🌸{RST}\n")
            break

        # History scan
        if low == "history":
            cmd_history()
            continue

        # Quick DB search
        if low.startswith("search "):
            term = raw[7:].strip()
            cmd_search(term)
            continue

        # Color search
        if low.startswith("color "):
            color = raw[6:].strip()
            cmd_color(color)
            continue

        # Help
        if low in ("help", "?"):
            _print_interactive_help()
            continue

        # Treat as file/dir path
        images = _collect_images([raw])
        if images:
            _identify_and_print(images)
        else:
            print(f"  {YLW}⚠ No images found at that path.{RST}")
            print(f"  {DIM}Tip: paste an absolute path, or try 'search <name>'{RST}")


def _print_interactive_help():
    print(f"""
  {YLW}── fidentify Interactive Commands ──{RST}

  {CYN}<path>{RST}             Identify image(s) at path
  {CYN}search <term>{RST}     Search DB by plant name
  {CYN}color <color>{RST}     Search DB by bloom color
  {CYN}history{RST}           Re-identify from ascii_out/
  {CYN}help{RST}              This message
  {CYN}q / quit{RST}          Exit
""")


def cmd_identify(paths: List[str]):
    """Direct identification of file/dir arguments."""
    _banner()
    total = _ensure_db()
    print(f"  {GRN}✓ Calflora DB — {total} taxa{RST}")

    images = _collect_images(paths)
    if not images:
        print(f"  {RED}✗ No images found.{RST}")
        sys.exit(2)

    print(f"  {CYN}Scanning {len(images)} image(s)...{RST}")
    print(f"\n{MAG}{'═' * 72}{RST}")

    identified = _identify_and_print(images)

    print(f"\n{MAG}{'═' * 72}{RST}")
    print(f"  {CYN}🌸 Identified {identified}/{len(images)} image(s){RST}")
    print(f"  {DIM}DB: {calflora_db.DB_PATH}{RST}\n")


def cmd_history():
    """Re-identify everything in ascii_out/."""
    total = _ensure_db()
    if not _ASCII_OUT.is_dir():
        print(f"  {YLW}⚠ ascii_out/ not found at {_ASCII_OUT}{RST}")
        return

    ansi_files = sorted(_ASCII_OUT.glob("*.ansi.txt"))
    if not ansi_files:
        print(f"  {YLW}⚠ No .ansi.txt files in ascii_out/{RST}")
        return

    # Also try to locate original image files
    originals = plant_identify.discover_originals_from_ascii_out()
    all_targets = list(ansi_files) + originals

    # de-dup
    seen = set()
    images: List[Path] = []
    for p in all_targets:
        rp = str(p.resolve())
        if rp not in seen:
            seen.add(rp)
            images.append(p)

    print(f"  {CYN}🔍 Re-identifying {len(images)} item(s) from ascii_out/...{RST}")
    _identify_and_print(images)


def cmd_search(term: str):
    """Quick DB lookup by name."""
    results = calflora_db.search_by_name(term)
    if not results:
        print(f"  {YLW}⚠ No taxa matching '{term}'{RST}")
        return
    print(f"  {GRN}Found {len(results)} match(es) for '{term}':{RST}")
    for r in results:
        colors = r.get("bloom_colors", "")
        native = f"{GRN}native{RST}" if r.get("native") else f"{YLW}non-native{RST}"
        print(f"    {BLD}{r['common_name']:30s}{RST}  "
              f"{DIM}{r['scientific_name']:35s}{RST}  "
              f"[{colors}]  {native}")


def cmd_color(color: str):
    """Quick DB lookup by bloom color."""
    results = calflora_db.search_by_color(color)
    if not results:
