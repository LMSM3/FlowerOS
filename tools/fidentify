# ═══════════════════════════════════════════════════════════════════════════
#  Entry Point
# ═══════════════════════════════════════════════════════════════════════════

def main():
    args = sys.argv[1:]

    # No args → interactive REPL
    if not args:
        cmd_interactive()
        return

    first = args[0].lower() if args else ""

    if first in ("-h", "--help", "help"):
        print_usage()

    elif first == "--upload":
        cmd_upload()

    elif first == "--history":
        _banner()
        total = _ensure_db()
        print(f"  {GRN}✓ Calflora DB — {total} taxa{RST}")
        cmd_history()

    elif first == "--search" and len(args) > 1:
        _ensure_db()
        cmd_search(" ".join(args[1:]))

    elif first == "--color" and len(args) > 1:
        _ensure_db()
        cmd_color(args[1])

    elif first == "--sync":
        _banner()
        print(f"  {YLW}🌱 Syncing Calflora database...{RST}")
        total = calflora_db.sync(verbose=True)
        print(f"  {GRN}✓ Database ready — {total} taxa{RST}\n")

    elif first == "--watch" and len(args) > 1:
        cmd_watch(args[1])

    else:
        # Everything else is treated as file/dir paths to identify
        real_args = [a for a in args if not a.startswith("--")]
        if real_args:
            cmd_identify(real_args)
        else:
            print_usage()


if __name__ == "__main__":
    main()
