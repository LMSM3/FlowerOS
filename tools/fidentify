def cmd_upload():
    """Prompt for a file path (simulates 'upload' in terminal context)."""
    _banner()
    total = _ensure_db()
    print(f"  {GRN}✓ Calflora DB — {total} taxa{RST}")
    print()
    print(f"  {CYN}Paste or type the full path to your image:{RST}")
    print(f"  {DIM}(WSL, Windows, or /mnt/ paths all work){RST}")
    print()

    try:
        raw = input(f"  {MAG}image path ❯{RST} ").strip()
    except (EOFError, KeyboardInterrupt):
        print(f"\n  {DIM}Cancelled.{RST}")
        return

    if not raw:
        print(f"  {YLW}⚠ No path given.{RST}")
        return

    images = _collect_images([raw])
    if not images:
        print(f"  {RED}✗ No image found at: {raw}{RST}")
        return

    print(f"\n{MAG}{'═' * 72}{RST}")
    identified = _identify_and_print(images)
    print(f"\n{MAG}{'═' * 72}{RST}")
    print(f"  {CYN}🌸 Done — {identified} identified.{RST}\n")


def cmd_watch(directory: str, interval: float = 2.0):
    """Watch a directory for new images and auto-identify them."""
    _banner()
    total = _ensure_db()
    print(f"  {GRN}✓ Calflora DB — {total} taxa{RST}")

    watch_dir = _resolve_path(directory)
    if not watch_dir.is_dir():
        print(f"  {RED}✗ Not a directory: {watch_dir}{RST}")
        sys.exit(2)

    print(f"  {CYN}👁  Watching: {watch_dir}{RST}")
    print(f"  {DIM}Press Ctrl+C to stop.{RST}")
    print()

    seen_hashes: set = set()
    # Snapshot existing files
    for f in watch_dir.iterdir():
        if f.suffix.lower() in IMAGE_EXTS and f.is_file():
            seen_hashes.add(str(f.resolve()))

    def _sigint(sig, frame):
        print(f"\n  {DIM}Watch stopped.{RST}\n")
        sys.exit(0)
    signal.signal(signal.SIGINT, _sigint)

    while True:
        for f in watch_dir.iterdir():
            if f.suffix.lower() not in IMAGE_EXTS or not f.is_file():
                continue
            key = str(f.resolve())
            if key in seen_hashes:
                continue
            # New image detected
            seen_hashes.add(key)
            print(f"  {GRN}🆕 New image detected:{RST} {f.name}")
            results = plant_identify.identify_image(f)
            plant_identify.print_identification(f, results)
        time.sleep(interval)


