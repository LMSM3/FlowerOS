def _ensure_db() -> int:
    """Seed the DB if needed, return taxon count."""
    conn = calflora_db._ensure_db()
    calflora_db.seed_database(conn)
    total = conn.execute("SELECT COUNT(*) FROM taxa").fetchone()[0]
    conn.close()
    return total


def _resolve_path(raw: str) -> Path:
    """
    Resolve a path that may be:
      - A WSL path             /home/user/flower.jpg
      - A Windows-via-WSL path /mnt/c/Users/.../flower.jpg
      - A Windows path         C:\\Users\\...\\flower.jpg
      - A drag-dropped path    'quoted /path/to/file'
    """
    s = raw.strip().strip("'\"")
    if not s:
        return Path()

    # Windows drive letter → WSL mount  (C:\foo → /mnt/c/foo)
    m = re.match(r'^([A-Za-z]):[/\\](.*)$', s)
    if m:
        drive = m.group(1).lower()
        rest = m.group(2).replace("\\", "/")
        return Path(f"/mnt/{drive}/{rest}")

    return Path(s).expanduser()


def _collect_images(paths: List[str]) -> List[Path]:
    """Expand args into image file paths."""
    out: List[Path] = []
    for raw in paths:
        p = _resolve_path(raw)
        if p.is_dir():
            out += sorted(
                f for f in p.rglob("*")
                if f.suffix.lower() in IMAGE_EXTS and f.is_file()
            )
        elif p.is_file() and p.suffix.lower() in IMAGE_EXTS:
            out.append(p)
        elif p.is_file():
            # Might be an .ansi.txt from ascii_out — allow for keyword ID
            out.append(p)
        else:
            print(f"  {YLW}⚠ Not found:{RST} {p}")
    # de-dup
    seen = set()
    result = []
    for p in out:
        rp = str(p.resolve())
        if rp not in seen:
            seen.add(rp)
            result.append(p)
    return result


def _identify_and_print(images: List[Path]) -> int:
    """Run identification on a list of images. Returns count identified."""
    identified = 0
    for img in images:
        results = plant_identify.identify_image(img)
        plant_identify.print_identification(img, results)
        if results:
            identified += 1
    return identified


