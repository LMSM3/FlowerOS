{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "palette": {
    "fos-primary":   "{{ .Env.FLOWEROS_OMP_PRIMARY   | default \"#5faf5f\" }}",
    "fos-secondary": "{{ .Env.FLOWEROS_OMP_SECONDARY | default \"#af5faf\" }}",
    "fos-accent":    "{{ .Env.FLOWEROS_OMP_ACCENT    | default \"#5fafaf\" }}",
    "fos-warning":   "{{ .Env.FLOWEROS_OMP_WARNING   | default \"#afaf5f\" }}",
    "fos-error":     "{{ .Env.FLOWEROS_OMP_ERROR     | default \"#af5f5f\" }}",
    "fos-success":   "{{ .Env.FLOWEROS_OMP_SUCCESS   | default \"#5fdf5f\" }}",
    "fos-info":      "{{ .Env.FLOWEROS_OMP_INFO      | default \"#5f87df\" }}",
    "fos-muted":     "{{ .Env.FLOWEROS_OMP_MUTED     | default \"#808080\" }}",
    "fos-bg":        "{{ .Env.FLOWEROS_OMP_BG        | default \"#1e1e2e\" }}",
    "fos-fg":        "{{ .Env.FLOWEROS_OMP_FG        | default \"#cdd6f4\" }}"
  },
  "blocks": [
    {
      "type":      "prompt",
      "alignment": "left",
      "newline":   true,
      "segments": [
        {
          "type":            "text",
          "style":           "plain",
          "foreground":      "p:fos-muted",
          "template":        "╭─"
        },
        {
          "type":            "os",
          "style":           "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground":      "p:fos-fg",
          "background":      "p:fos-bg",
          "template":        " {{ .Icon }} "
        },
        {
          "type":            "session",
          "style":           "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground":      "p:fos-primary",
          "background":      "p:fos-bg",
          "template":        " {{ .UserName }}@{{ .HostName }} "
        },
        {
          "type":            "path",
          "style":           "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground":      "p:fos-accent",
          "background":      "p:fos-bg",
          "properties": {
            "style":      "agnoster_short",
            "max_depth":  3
          },
          "template":        " 🌿 {{ .Path }} "
        },
        {
          "type":            "git",
          "style":           "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground":      "p:fos-secondary",
          "foreground_templates": [
            "{{ if gt .Ahead 0 }}p:fos-warning{{ end }}",
            "{{ if gt .Behind 0 }}p:fos-error{{ end }}"
          ],
          "background":      "p:fos-bg",
          "properties": {
            "branch_icon":           " ",
            "fetch_status":          true,
            "fetch_upstream_icon":   true
          },
          "template":        " {{ .HEAD }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }} "
        },
        {
          "type":            "python",
          "style":           "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground":      "p:fos-warning",
          "background":      "p:fos-bg",
          "template":        "  {{ .Full }} "
        },
        {
          "type":            "text",
          "style":           "plain",
          "foreground":      "p:fos-primary",
          "template":        " {{ if .Env.FLOWEROS_THEME_LOADED }}✿ {{ .Env.FLOWEROS_THEME_LOADED }}{{ end }}"
        }
      ]
    },
    {
      "type":      "prompt",
      "alignment": "right",
      "segments": [
        {
          "type":            "executiontime",
          "style":           "plain",
          "foreground":      "p:fos-muted",
          "properties": {
            "threshold": 500
          },
          "template":        "⏱ {{ .FormattedMs }}"
        },
        {
          "type":            "time",
          "style":           "plain",
          "foreground":      "p:fos-info",
          "template":        " {{ .CurrentDate | date .Format }}",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ]
    },
    {
      "type":      "prompt",
      "alignment": "left",
      "newline":   true,
      "segments": [
        {
          "type":            "text",
          "style":           "plain",
          "foreground":      "p:fos-muted",
          "template":        "╰─"
        },
        {
          "type":            "text",
          "style":           "plain",
          "foreground":      "p:fos-success",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:fos-error{{ end }}"
          ],
          "template":        " {{ if gt .Code 0 }}✗{{ else }}🌸{{ end }} "
        }
      ]
    }
  ]
}
